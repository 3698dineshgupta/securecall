# ── Production Environment ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Domain
DOMAIN=yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Database
DB_PASSWORD=CHANGE_THIS_STRONG_RANDOM_PASSWORD_32CHARS

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_JWT_KEY_MINIMUM_64_CHARS_FOR_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_REFRESH_SECRET_KEY_64_CHARS

# Frontend Build Args
REACT_APP_API_URL=https://yourdomain.com/api
REACT_APP_SIGNALING_URL=wss://yourdomain.com/signaling
