# Server
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://yourdomain.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/securecall
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securecall
DB_USER=securecall_user
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
